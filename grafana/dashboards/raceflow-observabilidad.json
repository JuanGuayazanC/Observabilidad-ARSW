{
  "title": "RaceFlow - Observabilidad de Microservicios",
  "uid": "raceflow-observabilidad",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "tags": ["raceflow", "arsw"],
  "panels": [
    {
      "id": 1,
      "title": "Active rooms",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        { "expr": "raceflow_rooms_active", "legendFormat": "active rooms", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "title": "Connected athletes (WebSocket)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        { "expr": "raceflow_websocket_connections_active", "legendFormat": "connections", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "title": "Positions/sec",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        { "expr": "rate(raceflow_positions_received_total[1m])", "legendFormat": "positions/sec", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "title": "Ranking-cycle p99 latency (SLO <= 1s)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "raceflow_ranking_update_duration_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99 ranking update",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Rejected-position rate (by reason)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "sum by (reason) (rate(raceflow_positions_rejected_total[1m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Per-service HTTP average latency",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_server_requests_seconds_sum{job=~\"raceflow-.*\"}[1m])) / sum by (job) (rate(http_server_requests_seconds_count{job=~\"raceflow-.*\"}[1m]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "HTTP 5xx errors (by service)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_server_requests_seconds_count{job=~\"raceflow-.*\", status=~\"5..\"}[1m]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Session-persistence lag p99 (target < 2s)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 2.0 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "raceflow_sessions_persistence_lag_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99 persistence lag",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Events consumed by type",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "sum by (event_type) (rate(raceflow_events_consumed_total[1m]))",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ]
    }
  ]
}
